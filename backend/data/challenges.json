      {
        "stageId": 3,
        "title": "The High Ledges",
        "description": "The Goldcrown Usurpers command the watchtowers and cliffside positions above the pass \u2014 a paranoid, rain-soaked garrison that shoots first and never asks questions.",
        "enemies": [
