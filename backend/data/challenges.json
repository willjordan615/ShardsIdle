            },
            "failureEffect": {
              "type": "apply_direct_damage",
              "magnitude": 0.14,
              "narrative": "The party attempts to flank through a side tunnel and finds it occupied. They fight their way back to the main passage, bloodied."
            },
            "fallbackEffect": {
              "type": "apply_direct_damage",
              "magnitude": 0.18,
              "narrative": "The tunnels are a maze to those who don't know them. The Loyalists hear the party coming from three corridors away."
