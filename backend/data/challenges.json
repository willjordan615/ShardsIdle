            "dropChance": 0.2,
            "rarity": "common"
          }
        ]
      },
      {
        "stageId": 2,
        "title": "The Lower Tunnels",
        "description": "The Ironvein Loyalists hold the cave system beneath the pass \u2014 their shield walls fill every chokepoint and they fight with the grim endurance of men who have not retreated in four years.",
        "enemies": [
          {
            "enemyTypeID": "stone_guard_veteran",
            "countRange": [
              1,
              2
            ],
            "level": 5
          },
          {
            "enemyTypeID": "ironvein_conscript",
            "countRange": [
              2,
