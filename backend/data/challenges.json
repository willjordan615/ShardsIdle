[
  {
    "id": "challenge_goblin_camp",
    "name": "Goblin Encampment",
    "description": "Clear out a nest of goblins threatening the nearby village. A good test for fresh adventurers.",
    "difficulty": 1,
    "recommendedLevel": 1,
    "minPartySize": 1,
    "maxPartySize": 4,
    "stages": [
      {
        "stageId": 1,
        "title": "The Perimeter",
        "description": "Two scouts patrol the outer fence. They haven't spotted you yet.",
        "enemies": [
          { "enemyTypeID": "goblin_scout", "countRange": [2, 3], "level": 1 }
        ]
      },
      {
        "stageId": 2,
        "title": "The Archery Nest",
        "description": "You breach the fence, but an archer has line of sight from a watchtower!",
        "enemies": [
          { "enemyTypeID": "goblin_archer", "countRange": [1, 2], "level": 2 },
          { "enemyTypeID": "goblin_scout", "countRange": [1, 2], "level": 1 }
        ],
        "preCombatOpportunities": [
          {
            "id": "evasive_footwork_approach",
            "name": "Serpentine Approach",
            "requiredSkillID": "footwork",
            "checkStat": "ambition",
            "secondaryStat": "endurance",
            "difficultyThreshold": 45,
            "successEffect": {
              "type": "narrative_only",
              "magnitude": 0,
              "narrative": "Using expert Footwork, the party weaves through the arrow fire in a serpentine pattern. They reach cover untouched!"
            },
            "failureEffect": {
              "type": "apply_direct_damage",
              "magnitude": 0.20,
              "statScale": "maxHP",
              "narrative": "The footwork fails! A stray arrow catches a party member as they stumble."
            },
            "fallbackEffect": {
              "type": "apply_direct_damage",
              "magnitude": 0.30,
              "statScale": "maxHP",
              "narrative": "Lacking the Footwork skill to evade, the party is forced to sprint across open ground. Arrows rain down, striking home before they can reach cover!"
            }
          }
        ]
      }
    ],
    "rewards": {
      "baseXP": 300,
      "baseGold": 100,
      "lootTable": [
        { "itemID": "iron_sword", "rarity": "common", "dropChance": 0.35 },
        { "itemID": "leather_armor", "rarity": "common", "dropChance": 0.30 },
        { "itemID": "wooden_shield", "rarity": "common", "dropChance": 0.25 }
      ]
    }
  },
  {
    "id": "challenge_forest_dungeon",
    "name": "Forest Dungeon",
    "description": "Investigate strange sounds coming from the ancient forest ruins. Beware the venomous spiders.",
    "difficulty": 2,
    "recommendedLevel": 3,
    "minPartySize": 1,
    "maxPartySize": 4,
    "stages": [
      {
        "stageId": 1,
        "title": "Webbed Entrance",
        "description": "The entrance is covered in thick silk. Small spiders skitter in the shadows.",
        "enemies": [
          { "enemyTypeID": "spider_small", "countRange": [2, 4], "level": 3 }
        ],
        "preCombatOpportunities": [
          {
            "id": "burn_webs",
            "name": "Burn the Webs",
            "requiredSkillID": "fire_bolt",
            "checkStat": "ambition",
            "secondaryStat": "conviction",
            "difficultyThreshold": 40,
            "successEffect": {
              "type": "remove_enemy",
              "magnitude": 1,
              "narrative": "You burn the webs! One spider falls dead before combat starts."
            },
            "failureEffect": {
              "type": "apply_status",
              "status": "slowed",
              "duration": 2,
              "narrative": "The fire sputters. You get stuck in the sticky residue."
            },
            "fallbackEffect": {
              "type": "apply_status",
              "status": "slowed",
              "duration": 2,
              "narrative": "Lacking fire magic, you struggle through the webs manually, becoming slowed."
            }
          }
        ]
      },
      {
        "stageId": 2,
        "title": "The Fork in the Path",
        "description": "The tunnel splits. One way goes up, one goes down.",
        "stageBranches": [
          {
            "branchId": "path_high",
            "condition": {
              "type": "has_skill",
              "value": "climb"
            },
            "nextStageId": 3,
            "overrideDescription": "You scale the wall to the upper ledge, avoiding the lower traps."
          },
          {
            "branchId": "path_low",
            "condition": null,
            "nextStageId": 4,
            "overrideDescription": "Unable to climb, you crawl through the damp lower tunnel."
          }
        ]
      },
      {
        "stageId": 3,
        "title": "The Upper Ledge (Secret)",
        "description": "You overlook the Queen's chamber from above.",
        "enemies": [
          { "enemyTypeID": "spider_large", "countRange": [1, 1], "level": 4 }
        ]
      },
      {
        "stageId": 4,
        "title": "The Queen's Chamber",
        "description": "Deep inside, a massive spider guards its brood.",
        "enemies": [
          { "enemyTypeID": "spider_large", "countRange": [1, 2], "level": 4 },
          { "enemyTypeID": "spider_small", "countRange": [2, 3], "level": 3 }
        ]
      }
    ],
    "rewards": {
      "baseXP": 750,
      "baseGold": 250,
      "lootTable": [
        { "itemID": "steel_helm", "rarity": "uncommon", "dropChance": 0.40 },
        { "itemID": "silver_dagger", "rarity": "uncommon", "dropChance": 0.35 },
        { "itemID": "boots_speed", "rarity": "uncommon", "dropChance": 0.25 }
      ]
    }
  },
