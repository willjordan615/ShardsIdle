            "secondaryStat": "endurance",
            "difficultyThreshold": 80,
            "successEffect": {
              "type": "narrative_only",
              "narrative": "Your party's bearing gives the Loyalists pause. For a moment, the Stone-Guards hesitate \u2014 these are not the soft merchants they usually ambush. They readjust their formation, buying the party a breath."
            },
            "failureEffect": {
              "type": "narrative_only",
              "narrative": "The Loyalists take one look at the party and tighten their shields. They've seen enough desperation to recognize it."
