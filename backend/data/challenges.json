  {
    "id": "challenge_stone_tooth_pass",
    "name": "Stone Tooth Pass",
    "description": "A narrow mountain defile locked in a four-year dwarven succession war. Two degraded armies and a band of stranded merchants fight over the only safe route through the Godspine range. The party must choose a path through the pass \u2014 and deal with whoever controls it.",
    "difficulty": 3,
    "recommendedLevel": 5,
    "minPartySize": 1,
    "maxPartySize": 4,
    "stages": [
      {
        "stageId": 1,
        "title": "The Scree Approach",
        "description": "The approach to the pass is littered with abandoned supply wagons and skirmishing soldiers. Both factions are too busy bleeding each other to notice the party \u2014 until they do.",
        "enemies": [
          {
            "enemyTypeID": "ironvein_conscript",
            "countRange": [
              1,
              2
            ],
            "level": 4
          },
          {
            "enemyTypeID": "goldcrown_scout",
            "countRange": [
              1,
              2
            ],
            "level": 4
          }
        ],
        "preCombatOpportunities": [
          {
            "id": "spot_the_ambush",
            "name": "Read the Terrain",
            "spawnChance": 0.6,
            "checkType": "skill",
            "requiredSkillID": "sense",
            "checkStat": "ambition",
            "secondaryStat": "endurance",
            "difficultyThreshold": 40,
            "successEffect": {
              "type": "narrative_only",
              "narrative": "Your party spots the caltrop fields and loose-rock triggers before stepping into them, skirting the ambush entirely and entering the fight from a flanking position."
            },
            "failureEffect": {
              "type": "apply_direct_damage",
              "magnitude": 0.12,
              "narrative": "A loose-rock trigger catches the party off guard. Stones cascade from the ridge, wounding everyone before the fighting even begins."
            },
            "fallbackEffect": {
              "type": "apply_direct_damage",
              "magnitude": 0.18,
              "narrative": "Without anyone skilled in reading terrain, the party walks straight into the caltrop fields. The Scouts are already laughing when the real fight starts."
            }
          },
          {
            "id": "consortium_warning",
            "name": "A Merchant's Warning",
            "spawnChance": 0.5,
            "checkType": "stat",
            "checkStat": "harmony",
            "secondaryStat": "ambition",
            "difficultyThreshold": 55,
            "successEffect": {
              "type": "narrative_only",
              "narrative": "A stranded merchant waves the party down before they enter the killing ground. She sketches the patrol routes in the dirt \u2014 the party enters the fight knowing exactly where everyone is."
            },
            "failureEffect": {
              "type": "narrative_only",
              "narrative": "A merchant calls out a warning, but the party can't parse her frantic gesturing in time. They nod politely and walk straight into the skirmish line."
            }
          },
          {
            "id": "bad_luck",
            "name": "Poorly Timed Arrival",
            "spawnChance": 0.3,
            "checkType": "random",
            "successChance": 0.0,
            "successEffect": {
              "type": "narrative_only",
              "narrative": "The timing is perfect \u2014 the soldiers are distracted."
            },
            "failureEffect": {
              "type": "apply_direct_damage",
              "magnitude": 0.1,
              "narrative": "The party crests the rise just as a stray boulder from a rockslide rolls through the approach. Nobody is seriously hurt, but everyone is shaken."
            }
          }
        ],
        "stageBranches": [
          {
            "condition": {
              "type": "random",
              "chance": 0.5
            },
            "nextStageId": 2,
            "overrideDescription": "The lower tunnels are accessible \u2014 the Ironvein hold this ground."
          },
          {
            "nextStageId": 3
          }
        ],
        "lootTable": [
          {
            "itemID": "health_potion_minor",
            "dropChance": 0.4,
            "rarity": "common"
          },
          {
            "itemID": "stamina_potion_minor",
