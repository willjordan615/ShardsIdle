  {
    "id": "challenge_forest_dungeon",
    "name": "Forest Dungeon",
    "description": "Investigate strange sounds coming from the ancient forest ruins. Beware the venomous spiders.",
    "difficulty": 2,
    "recommendedLevel": 3,
    "minPartySize": 1,
    "maxPartySize": 4,
    "stages": [
      {
        "stageId": 1,
        "title": "Webbed Entrance",
        "description": "The entrance is covered in thick silk. Small spiders skitter in the shadows.",
        "enemies": [
          {
            "enemyTypeID": "spider_small",
            "countRange": [
              2,
              4
            ],
            "level": 3
          }
        ],
        "preCombatOpportunities": [
          {
            "id": "burn_webs",
            "name": "Burn the Webs",
            "requiredSkillID": "produce_flame",
            "checkStat": "ambition",
            "secondaryStat": "conviction",
            "difficultyThreshold": 40,
            "successEffect": {
              "type": "remove_enemy",
              "magnitude": 1,
              "narrative": "You burn the webs! One spider falls dead before combat starts."
            },
            "failureEffect": {
              "type": "apply_status",
              "status": "slow",
              "duration": 2,
              "narrative": "The fire sputters. You get stuck in the sticky residue."
            },
            "fallbackEffect": {
              "type": "apply_status",
              "status": "slow",
              "duration": 2,
              "narrative": "Lacking fire magic, you struggle through the webs manually, becoming slowed."
            }
          }
        ]
      },
      {
        "stageId": 2,
        "title": "The Fork in the Path",
        "description": "The tunnel splits. One way goes up, one goes down.",
        "stageBranches": [
          {
            "branchId": "path_high",
            "condition": {
              "type": "has_skill",
              "value": "climb"
            },
            "nextStageId": 3,
            "overrideDescription": "You scale the wall to the upper ledge, avoiding the lower traps."
          },
          {
            "branchId": "path_low",
            "condition": null,
            "nextStageId": 4,
            "overrideDescription": "Unable to climb, you crawl through the damp lower tunnel."
          }
        ]
      },
      {
        "stageId": 3,
        "title": "The Upper Ledge (Secret)",
        "description": "You overlook the Queen's chamber from above.",
        "enemies": [
          {
            "enemyTypeID": "spider_large",
            "countRange": [
              1,
              1
            ],
            "level": 4
          }
        ]
      },
      {
        "stageId": 4,
        "title": "The Queen's Chamber",
        "description": "Deep inside, a massive spider guards its brood.",
        "enemies": [
          {
            "enemyTypeID": "spider_large",
            "countRange": [
              1,
              2
            ],
            "level": 4
          },
          {
            "enemyTypeID": "spider_small",
            "countRange": [
              2,
              3
            ],
            "level": 3
          }
        ]
      }
